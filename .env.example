# Copy this file to .env and fill in your values.
# See SETUP_GUIDE.md for step-by-step instructions.

# From Google Cloud Console → Credentials → OAuth 2.0 Client ID
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# The ID of your Google Spreadsheet (from the URL: /d/THIS_PART/edit)
REACT_APP_SPREADSHEET_ID=your_spreadsheet_id_here

# The ID of the Google Drive folder where receipts are stored (from URL)
REACT_APP_DRIVE_FOLDER_ID=your_drive_folder_id_here
